{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>\n" | safeHTML -}}
{{- printf "<urlset xmlns=\"http://www.sitemaps.org/schemas/sitemap/0.9\">\n" | safeHTML -}}

{{/* Home */}}
{{- $homeRobots := "" -}}
{{- with .Site.Home.Params.robots -}}{{- $homeRobots = lower . -}}{{- end -}}
{{- if not (strings.Contains $homeRobots "noindex") -}}
  <url>
    <loc>{{ .Site.Home.Permalink }}</loc>
    <lastmod>{{ (.Site.Home.Lastmod | default .Site.Home.Date).Format "2006-01-02" }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
{{- end -}}

{{/* Sections */}}
{{- range .Site.Sections -}}
  {{- $robots := "" -}}
  {{- with .Params.robots -}}{{- $robots = lower . -}}{{- end -}}
  {{- if not (strings.Contains $robots "noindex") -}}
    <url>
      <loc>{{ .Permalink }}</loc>
      <lastmod>{{ (.Lastmod | default .Date).Format "2006-01-02" }}</lastmod>
      <changefreq>weekly</changefreq>
      <priority>0.6</priority>
    </url>
  {{- end -}}
{{- end -}}

{{/* Regular pages */}}
{{- range .Site.RegularPages -}}
  {{- $robots := "" -}}
  {{- with .Params.robots -}}{{- $robots = lower . -}}{{- end -}}
  {{- if not (strings.Contains $robots "noindex") -}}
    {{- $priority := "0.5" -}}
    {{- $changefreq := "weekly" -}}

    {{- if and (eq .Section "modelos") (eq .Layout "recambio") -}}
      {{- $priority = "0.8" -}}
    {{- else if and (eq .Section "modelos") (eq .Layout "problema") -}}
      {{- $priority = "0.7" -}}
    {{- else if eq .Section "marcas" -}}
      {{- $priority = "0.6" -}}
    {{- else if eq .Section "guias" -}}
      {{- $priority = "0.5" -}}
      {{- $changefreq = "monthly" -}}
    {{- end -}}

    <url>
      <loc>{{ .Permalink }}</loc>
      <lastmod>{{ (.Lastmod | default .Date).Format "2006-01-02" }}</lastmod>
      <changefreq>{{ $changefreq }}</changefreq>
      <priority>{{ $priority }}</priority>
    </url>
  {{- end -}}
{{- end -}}

{{- printf "</urlset>\n" | safeHTML -}}